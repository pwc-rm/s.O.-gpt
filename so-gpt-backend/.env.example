# ─────────────────────────────────────────────────────────────────────────────
# S.O. GPT Backend — Environment Variables
# Copy this file to .env and fill in the values from the Azure Portal.
# .env is in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend Security ──────────────────────────────────────────────────────────
# Generate a strong random string: python3 -c "import secrets; print(secrets.token_hex(32))"
BACKEND_API_KEY=

# ── Azure OpenAI (via AI Foundry AI Gateway) ──────────────────────────────────
# Found in: Azure AI Foundry → your hub → Settings → Endpoints
OPENAI_ENDPOINT=https://<your-hub-name>.openai.azure.com/
OPENAI_API_KEY=
OPENAI_CHAT_DEPLOYMENT=gpt-4o-deployment
OPENAI_EMBEDDING_DEPLOYMENT=embedding-deployment
OPENAI_QUERY_REWRITE_DEPLOYMENT=gpt-4o-mini-deployment

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Found in: AI Search resource → Overview (URL) + Keys
SEARCH_ENDPOINT=https://srch-so-gpt-showcase.search.windows.net
SEARCH_API_KEY=
SEARCH_INDEX_NAME=so-gpt-index

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Found in: Cosmos DB → Keys → Primary Connection String
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=so-gpt-db
COSMOS_CONTAINER=sessions

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Found in: Storage Account → Security + networking → Access keys → Connection string
BLOB_CONNECTION_STRING=
BLOB_CONTAINER_NAME=documents

# ── Azure Document Intelligence (nur für PDFs) ───────────────────────────────
# Word / PowerPoint / Excel werden lokal via markitdown verarbeitet (kein API-Call).
# Document Intelligence wird nur für PDFs benötigt (maschinenlesbar + gescannt/OCR).
# Found in: Document Intelligence resource → Keys and Endpoint
DOCINTEL_ENDPOINT=https://docintel-so-gpt.<region>.cognitiveservices.azure.com/
DOCINTEL_API_KEY=

# ── Bing Web Search (optional — Schritt 3g im Schlachtplan) ──────────────────
BING_API_KEY=

# ── Retrieval Tuning ──────────────────────────────────────────────────────────
TOP_N_CHUNKS=5
RELEVANCE_THRESHOLD=0.75
SESSION_HISTORY_TURNS=6
